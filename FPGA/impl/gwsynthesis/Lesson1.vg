defparam pllvr_inst_s4.CLKOUT_FT_DIR=1'b1;
defparam pllvr_inst_s4.DEVICE="GW1NSR-4C";
defparam pllvr_inst_s4.DUTYDA_SEL="1000";
defparam pllvr_inst_s4.DYN_DA_EN="true";
defparam pllvr_inst_s4.DYN_FBDIV_SEL="false";
defparam pllvr_inst_s4.DYN_IDIV_SEL="false";
defparam pllvr_inst_s4.DYN_ODIV_SEL="false";
defparam pllvr_inst_s4.DYN_SDIV_SEL=2;
