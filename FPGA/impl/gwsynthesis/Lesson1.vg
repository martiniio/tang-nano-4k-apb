module soc_top (
  xtal_clk,
  reset_n,
  gpio,
  UART_TX,
  UART_RX
)
;
input xtal_clk;
input reset_n;
inout [1:0] gpio;
output UART_TX;
input UART_RX;
wire xtal_clk_d;
wire reset_n_d;
wire UART_RX_d;
wire UART_TX_d;
wire master_penable;
wire master_pwrite;
wire master_psel1;
wire master_pclk;
wire master_pready1;
wire [3:0] master_pstrb;
wire [7:2] master_paddr;
wire [31:0] master_pwdata;
wire [31:0] master_prdata1;
wire VCC;
wire GND;
  IBUF xtal_clk_ibuf (
    .O(xtal_clk_d),
    .I(xtal_clk) 
);
  IBUF reset_n_ibuf (
    .O(reset_n_d),
    .I(reset_n) 
);
  IBUF UART_RX_ibuf (
    .O(UART_RX_d),
    .I(UART_RX) 
);
  OBUF UART_TX_obuf (
    .O(UART_TX),
    .I(UART_TX_d) 
);
  Gowin_EMPU_Top cortexM3_inst (
    .master_pclk(master_pclk),
    .reset_n_d(reset_n_d),
    .UART_RX_d(UART_RX_d),
    .master_pready1(master_pready1),
    .master_prdata1(master_prdata1[31:0]),
    .UART_TX_d(UART_TX_d),
    .master_penable(master_penable),
    .master_pwrite(master_pwrite),
    .master_psel1(master_psel1),
    .master_pstrb(master_pstrb[3:0]),
    .master_paddr(master_paddr[7:2]),
    .master_pwdata(master_pwdata[31:0]),
    .gpio(gpio[1:0])
);
  Gowin_PLLVR pllvr_inst (
    .xtal_clk_d(xtal_clk_d),
    .master_pclk(master_pclk)
);
  apb_slave_regbank apb_slave_inst (
    .master_pclk(master_pclk),
    .master_pwrite(master_pwrite),
    .master_penable(master_penable),
    .master_psel1(master_psel1),
    .reset_n_d(reset_n_d),
    .master_paddr(master_paddr[7:2]),
    .master_pwdata(master_pwdata[31:0]),
    .master_pstrb(master_pstrb[3:0]),
    .master_pready1(master_pready1),
    .master_prdata1(master_prdata1[31:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* soc_top */
